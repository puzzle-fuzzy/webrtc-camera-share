{
  "name": "@voasx/p2p-video",
  "version": "1.0.0",
  "description": "基于 WebRTC 和 Bun WebSocket 信令的一发多收摄像头共享演示",
  "type": "module",
  "scripts": {
    "dev": "bun --watch run src/main.ts",
    "start": "bun run src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "verify": "bun run typecheck && bun test"
  },
  "keywords": [
    "webrtc",
    "websocket",
    "bun"
  ],
  "license": "MIT",
  "packageManager": "bun@1.4.0",
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}

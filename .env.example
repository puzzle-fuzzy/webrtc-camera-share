# Copy to .env and replace every empty required value before using Compose.
APP_DOMAIN=
ACME_EMAIL=
APP_IMAGE_TAG=local

# Generate independently, for example with: python -X utf8 -c "import secrets; print(secrets.token_urlsafe(48))"
METRICS_TOKEN=
TURN_SHARED_SECRET=

TURN_DOMAIN=
# Use PUBLIC_IP for a directly addressed host, or PUBLIC_IP/PRIVATE_IP behind 1:1 NAT.
TURN_EXTERNAL_IP=
TURN_CERT_FILE=
TURN_KEY_FILE=

MAX_CONNECTIONS=256
MAX_CONNECTIONS_PER_IP=32
MAX_RECEIVERS=8
MAX_ROOMS=128
RUST_LOG=webrtc_camera_share_server=info
